# API Configuration
VITE_API_BASE_URL=http://localhost:4005/api/v1

# Optional: If you need the raw API URL without prefix
VITE_API_URL=http://localhost:4005


# ============================================
# STRIPE CONFIGURATION
# ============================================
# Publishable key for Stripe Elements (client-side)
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# PayPal Configuration (optional)
# VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# Apple Pay Configuration (optional)
# VITE_APPLE_PAY_MERCHANT_ID=merchant.com.your-domain

# Google Pay Configuration (optional)
# VITE_GOOGLE_PAY_MERCHANT_ID=your_google_pay_merchant_id
# VITE_GOOGLE_PAY_MERCHANT_NAME=Your Store Name
